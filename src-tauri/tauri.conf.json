{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CIMon",
  "version": "0.1.4",
  "identifier": "io.github.fuitad.cimon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "CIMon",
        "width": 860,
        "height": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzQkVDNkVCQTVGNkEyMEMKUldRTW92YWw2OGErSTlZekxCZjhXQmU5VE4wZHVhc2R6NmUyNzVBNVRNS1RoT000ZDdpSW9qQXYK",
      "endpoints": [
        "https://github.com/Fuitad/cimon/releases/latest/download/latest.json"
      ]
    }
  }
}
